      "cell_type": "code",
      "source": [
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "\n",
        "vec1 = embeddings.embed_query(\"cat\")\n",
        "vec2 = embeddings.embed_query(\"dog\")\n",
        "\n",
        "similarity = cosine_similarity([vec1], [vec2])\n",
        "\n",
        "print(similarity)"
      ],
